<?xml version="1.0" encoding="utf-8"?>
<!-- Background for the rounded search bar -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <solid android:color="#F5F5F5"/> <!-- Light neutral background color -->

    <corners android:radius="24dp"/> <!-- Fully rounded corners for pill shape -->

    <stroke
        android:width="1dp"
        android:color="#DDDDDD"/> <!-- Light border -->

    <padding
        android:left="16dp"
        android:top="8dp"
        android:right="16dp"
        android:bottom="8dp"/>
</shape>